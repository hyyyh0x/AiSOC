      "inline_policies": []
    }
  ],
  "groups": [
    {
      "id": "g-data-readers",
      "name": "DataReaders",
      "attached_policies": ["p-readers-s3"],
      "inline_policies": []
    },
    {
      "id": "g-data-writers",
      "name": "DataWriters",
      "attached_policies": ["p-writers-s3", "p-writers-sqs"],
      "inline_policies": []
    }
  ],
  "policies": [
    {
      "id": "p-alice-direct",
      "name": "AliceDirectKMS",
      "kind": "identity",
      "document": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": ["kms:Decrypt", "kms:DescribeKey"],
            "Resource": "arn:aws:kms:us-east-1:111122223333:key/finance"
          }
        ]
      }
    },
    {
      "id": "p-bob-inline",
      "name": "BobInline",
      "kind": "identity",
      "document": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": "s3:DeleteObject",
            "Resource": "arn:aws:s3:::reports-prod/*"
          }
        ]
      }
    },
    {
      "id": "p-dave-admin",
      "name": "DaveAdmin",
      "kind": "identity",
      "document": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": "*",
            "Resource": "*"
          }
        ]
      }
    },
    {
      "id": "p-pipeline-cicd",
      "name": "PipelineCICD",
      "kind": "identity",
      "document": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": ["s3:Get*", "s3:List*"],
            "Resource": [
              "arn:aws:s3:::artifacts-prod",
              "arn:aws:s3:::artifacts-prod/*"
            ]
          },
          {
            "Effect": "Allow",
            "Action": "ec2:Describe*",
            "Resource": "*"
          }
        ]
      }
    },
    {
      "id": "p-erin-conditional",
      "name": "ErinConditional",
      "kind": "identity",
      "document": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": "s3:GetObject",
            "Resource": "arn:aws:s3:::reports-prod/*",
            "Condition": {
              "StringEquals": {"aws:RequestedRegion": "us-east-1"}
            }
          }
        ]
      }
    },
    {
      "id": "p-readers-s3",
      "name": "ReadersS3",
      "kind": "identity",
      "document": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": ["s3:GetObject", "s3:ListBucket"],
            "Resource": [
              "arn:aws:s3:::reports-prod",
              "arn:aws:s3:::reports-prod/*"
            ]
          }
        ]
      }
    },
    {
      "id": "p-writers-s3",
      "name": "WritersS3",
      "kind": "identity",
      "document": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": ["s3:PutObject", "s3:DeleteObject"],
            "Resource": "arn:aws:s3:::reports-prod/*"
          }
        ]
      }
    },
    {
      "id": "p-writers-sqs",
      "name": "WritersSQS",
      "kind": "identity",
      "document": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": ["sqs:SendMessage", "sqs:GetQueueAttributes"],
            "Resource": "arn:aws:sqs:us-east-1:111122223333:ingest-queue"
          }
        ]
      }
    },
    {
      "id": "p-bucket-reports",
      "name": "ReportsBucketPolicy",
      "kind": "resource",
      "document": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Deny",
            "Principal": "*",
            "Action": "s3:DeleteBucket",
            "Resource": "arn:aws:s3:::reports-prod"
          },
          {
            "Effect": "Allow",
            "Principal": {"AWS": "arn:aws:iam::111122223333:role/pipeline-runner"},
            "Action": "s3:PutObject",
            "Resource": "arn:aws:s3:::reports-prod/*"
          }
        ]
      }
    },
    {
      "id": "p-bucket-artifacts",
      "name": "ArtifactsBucketPolicy",
      "kind": "resource",
      "document": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Principal": {"AWS": "*"},
            "Action": "s3:GetObject",
            "Resource": "arn:aws:s3:::artifacts-prod/*"
          }
        ]
      }
    },
    {
      "id": "p-key-finance",
      "name": "FinanceKeyPolicy",
      "kind": "resource",
      "document": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Principal": {"AWS": "arn:aws:iam::111122223333:user/alice"},
            "Action": ["kms:Decrypt", "kms:Encrypt", "kms:DescribeKey"],
            "Resource": "*"
          },
          {
            "Effect": "Deny",
            "Principal": "*",
            "Action": "kms:ScheduleKeyDeletion",
            "Resource": "*"
          }
        ]
      }
    },
    {
      "id": "p-queue-ingest",
      "name": "IngestQueuePolicy",
      "kind": "resource",
      "document": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Principal": {"AWS": "arn:aws:iam::111122223333:role/pipeline-runner"},
            "Action": "sqs:SendMessage",
            "Resource": "*"
          }
        ]
      }
    },
    {
      "id": "p-scp-allow-baseline",
      "name": "SCPAllowBaseline",
      "kind": "scp",
      "document": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": [
              "s3:*", "kms:*", "sqs:*", "ec2:Describe*", "iam:Get*"
            ],
            "Resource": "*"
          }
        ]
      }
    },
    {
      "id": "p-scp-deny-iam-write",
      "name": "SCPDenyIamWrite",
      "kind": "scp",
      "document": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Deny",
            "Action": ["iam:CreateRole", "iam:DeleteRole", "iam:AttachRolePolicy"],
            "Resource": "*"
          },
          {
            "Effect": "Deny",
            "Action": "s3:DeleteBucket",
            "Resource": "*"
          }
        ]
      }
    }
  ],
  "scps": ["p-scp-allow-baseline", "p-scp-deny-iam-write"],
  "resources": [
