{
  "_about": "Complex AWS IAM fixture for the T3.2 effective-permissions resolver. Exercises identity-based policies (direct + via group), resource-based policies (S3 bucket policy, KMS key policy, SQS queue policy), Service Control Policies (allow-list + explicit deny), wildcard expansion against a per-resource action catalogue, conditions (StringEquals, StringLike), and deny-overrides. The aligned `aws_iam_simulator.json` next to this fixture is the synthesised IAM Policy Simulator reference set the test gate compares against — it captures, for 50 (principal, resource) pairs, the exact allow set every public IAM call resolves to with the same input.",
  "account_id": "111122223333",
  "action_catalogue": {
    "s3": [
      "s3:GetObject", "s3:PutObject", "s3:DeleteObject", "s3:ListBucket",
      "s3:GetBucketAcl", "s3:PutBucketAcl", "s3:GetObjectVersion",
      "s3:PutBucketPolicy", "s3:DeleteBucket", "s3:GetBucketLocation"
    ],
    "kms": [
      "kms:Decrypt", "kms:Encrypt", "kms:GenerateDataKey", "kms:DescribeKey",
      "kms:ListKeys", "kms:ScheduleKeyDeletion"
    ],
    "sqs": [
      "sqs:SendMessage", "sqs:ReceiveMessage", "sqs:DeleteMessage",
      "sqs:GetQueueAttributes", "sqs:PurgeQueue"
    ],
    "ec2": [
      "ec2:DescribeInstances", "ec2:StartInstances", "ec2:StopInstances",
      "ec2:TerminateInstances", "ec2:RunInstances"
    ],
    "iam": [
      "iam:GetRole", "iam:PassRole", "iam:CreateRole", "iam:DeleteRole",
      "iam:ListRoles", "iam:AttachRolePolicy"
    ]
  },
  "principals": [
