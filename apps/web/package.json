{
  "name": "@aisoc/web",
  "version": "7.5.0",
  "private": true,
  "description": "AiSOC SOC Console - Next.js 14 Frontend",
  "license": "MIT",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "screencast": "playwright test --project=screencast",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --output-dir storybook-static",
    "test-storybook": "test-storybook",
    "visual": "PLAYWRIGHT_PROJECT=visual playwright test --project=visual",
    "visual:update": "PLAYWRIGHT_PROJECT=visual playwright test --project=visual --update-snapshots",
    "e2e": "PLAYWRIGHT_PROJECT=journey playwright test --project=journey"
  },
  "dependencies": {
    "@aisoc/types": "workspace:*",
    "@aisoc/ui": "workspace:*",
    "@monaco-editor/react": "^4.6.0",
    "@xyflow/react": "^12.11.0",
    "clsx": "^2.1.0",
    "cmdk": "^1.1.1",
    "cytoscape": "^3.28.1",
    "cytoscape-fcose": "^2.2.0",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.40.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hot-toast": "^2.4.1",
    "recharts": "^3.9.0",
    "swr": "^2.2.4",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^9.1.0",
    "@storybook/addon-themes": "^9.1.0",
    "@storybook/react-vite": "^9.1.0",
    "@storybook/test-runner": "^0.23.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/cytoscape": "^3.21.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@playwright/test": "^1.49.0",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.17",
    "axe-core": "^4.11.4",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.2.7",
    "http-server": "^14.1.1",
    "jsdom": "^24.0.0",
    "postcss": "^8.5.15",
    "storybook": "^9.1.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.6",
    "vitest-axe": "^0.1.0"
  }
}
